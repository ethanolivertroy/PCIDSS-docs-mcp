      "number": "1.4",
      "level": 2,
      "parentId": "1",
      "title": "- 1.4 Network connections between trusted and untrusted networks are controlled.",
      "statement": "- 1.4 Network connections between trusted and untrusted networks are controlled.",
      "definedApproach": {
