    {
      "id": "9.5.1",
      "number": "9.5.1",
      "level": 3,
      "parentId": "9.5",
      "title": "POI devices that capture payment card via direct physical interaction with the payment form factor a...",
      "statement": "POI devices that capture payment card via direct physical interaction with the payment form factor are protected from tampering and unauthorized substitution, including the following: • Maintaining a list of POI devices. • Periodically inspecting POI devices to look tampering or unauthorized substitution. • Training personnel to be aware of suspicious behavior and to report tampering or unauthorized substitution of devices. Customized Approach Objective The entity has defined procedures to protect and",
      "definedApproach": {
        "requirement": "POI devices that capture payment card via direct physical interaction with the payment form factor are protected from tampering and unauthorized substitution, including the following: • Maintaining a list of POI devices. • Periodically inspecting POI devices to look tampering or unauthorized substitution. • Training personnel to be aware of suspicious behavior and to report tampering or unauthorized substitution of devices. Customized Approach Objective The entity has defined procedures to protect and",
        "testingProcedures": []
      },
      "customizedApproach": {
        "objective": "The entity has defined procedures to protect and",
        "exampleImplementations": []
      }
    },
    {
      "id": "9.5.1.1",
      "number": "9.5.1.1",
      "level": 4,
      "parentId": "9.5.1",
      "title": "An up-to-date list of POI devices is maintained, including: • Make and model of the device. • Locati...",
      "statement": "An up-to-date list of POI devices is maintained, including: • Make and model of the device. • Location of device. • Device serial number or other methods of unique identification.",
      "definedApproach": {
        "requirement": "An up-to-date list of POI devices is maintained, including: • Make and model of the device. • Location of device. • Device serial number or other methods of unique identification.",
        "testingProcedures": [
          {
            "id": "9.5.1.1.a",
            "description": "Examine the list of POI devices to verify it includes all elements specified in this requirement. 9.5.1.1.b Observe POI devices and device locations and compare to devices in the list to verify that the list is accurate and up to date."
          }
        ]
      },
      "customizedApproach": {
        "objective": "",
        "exampleImplementations": []
      }
    },
    {
      "id": "9.5.1.2",
      "number": "9.5.1.2",
      "level": 4,
      "parentId": "9.5.1",
      "title": "POI device surfaces are periodically inspected to detect tampering and unauthorized substitution. Cu...",
      "statement": "POI device surfaces are periodically inspected to detect tampering and unauthorized substitution. Customized Approach Objective Point of interaction devices cannot be tampered with, substituted without authorization, or have skimming attachments installed without timely detection.",
      "definedApproach": {
        "requirement": "POI device surfaces are periodically inspected to detect tampering and unauthorized substitution. Customized Approach Objective Point of interaction devices cannot be tampered with, substituted without authorization, or have skimming attachments installed without timely detection.",
        "testingProcedures": [
          {
            "id": "9.5.1.2.a",
            "description": "Examine documented procedures to verify processes are defined for periodic inspections of POI device surfaces to detect tampering and unauthorized substitution. 9.5.1.2.b Interview responsible personnel and observe inspection processes to verify: • Personnel are aware of procedures for inspecting devices. • All devices are periodically inspected for evidence of tampering and unauthorized substitution."
          }
        ]
      },
      "customizedApproach": {
        "objective": "Point of interaction devices cannot be tampered with, substituted without authorization, or have skimming attachments installed without timely detection.",
        "exampleImplementations": []
      }
    },
    {
      "id": "9.5.1.3",
      "number": "9.5.1.3",
      "level": 4,
      "parentId": "9.5.1",
      "title": "Training is provided for personnel in POI environments to be aware of attempted tampering or replace...",
      "statement": "Training is provided for personnel in POI environments to be aware of attempted tampering or replacement of POI devices, and includes: • Verifying the identity of any third-party persons claiming to be repair or maintenance personnel, before granting them access to modify or troubleshoot devices. • Procedures to ensure devices are not installed, replaced, or returned without verification. • Being aware of suspicious behavior around devices. • Reporting suspicious behavior and indications device tampering or substitution to appropriate personnel. Customized Approach Objective Personnel are knowledgeable about the types of attacks against POI devices, the entity's technical and procedural countermeasures, and can access assistance and guidance when required.",
      "definedApproach": {
        "requirement": "Training is provided for personnel in POI environments to be aware of attempted tampering or replacement of POI devices, and includes: • Verifying the identity of any third-party persons claiming to be repair or maintenance personnel, before granting them access to modify or troubleshoot devices. • Procedures to ensure devices are not installed, replaced, or returned without verification. • Being aware of suspicious behavior around devices. • Reporting suspicious behavior and indications device tampering or substitution to appropriate personnel. Customized Approach Objective Personnel are knowledgeable about the types of attacks against POI devices, the entity's technical and procedural countermeasures, and can access assistance and guidance when required.",
        "testingProcedures": []
      },
      "customizedApproach": {
        "objective": "Personnel are knowledgeable about the types of attacks against POI devices, the entity's technical and procedural countermeasures, and can access assistance and guidance when required.",
        "exampleImplementations": []
      }
    },
