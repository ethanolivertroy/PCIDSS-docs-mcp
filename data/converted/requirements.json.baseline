    {
      "id": "7.1",
      "number": "7.1",
      "level": 2,
      "parentId": "7",
      "title": "- 7.1 Processes and mechanisms for restricting access to system components and cardholder data by business need to know are defined and understood.",
      "statement": "- 7.1 Processes and mechanisms for restricting access to system components and cardholder data by business need to know are defined and understood.",
      "definedApproach": {
        "requirement": "",
