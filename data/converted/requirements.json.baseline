      "id": "2.3",
      "number": "2.3",
      "level": 2,
      "parentId": "2",
      "title": "- 2.3 Wireless environments are configured and managed securely.",
      "statement": "- 2.3 Wireless environments are configured and managed securely.",
      "definedApproach": {
        "requirement": "",
        "testingProcedures": []
      },
      "customizedApproach": {
        "objective": "",
        "exampleImplementations": []
      }
    },
    {
      "id": "2.3.1",
      "number": "2.3.1",
      "level": 3,
      "parentId": "2.3",
      "title": "For wireless environments connected to the CDE or transmitting account data, all wireless vendor def...",
      "statement": "For wireless environments connected to the CDE or transmitting account data, all wireless vendor defaults are changed at installation or are confirmed to be secure, including but not limited to: • Default wireless encryption keys. • Passwords on wireless access points. • SNMP defaults. • Any other security-related wireless vendor defaults.",
      "definedApproach": {
        "requirement": "For wireless environments connected to the CDE or transmitting account data, all wireless vendor defaults are changed at installation or are confirmed to be secure, including but not limited to: • Default wireless encryption keys. • Passwords on wireless access points. • SNMP defaults. • Any other security-related wireless vendor defaults.",
        "testingProcedures": [
          {
            "id": "2.3.1.a",
            "description": "Examine policies and procedures and interview responsible personnel to verify that processes are defined for wireless vendor defaults to either change them upon installation or to confirm them to be secure in accordance with all elements of this requirement. 2.3.1.b Examine vendor documentation and observe a system administrator logging into wireless devices to verify: • SNMP defaults are not used. • Default passwords/passphrases on wireless access points are not used. 2.3.1.c Examine vendor documentation and wireless configuration settings to verify other"
          }
        ]
      },
      "customizedApproach": {
        "objective": "",
        "exampleImplementations": []
      }
    },
    {
      "id": "2.3.2",
      "number": "2.3.2",
      "level": 3,
      "parentId": "2.3",
      "title": "For wireless environments connected to the CDE or transmitting account data, wireless encryption key...",
      "statement": "For wireless environments connected to the CDE or transmitting account data, wireless encryption keys are changed as follows: • Whenever personnel with knowledge of the key leave the company or the role for which the knowledge was necessary. • Whenever a key is suspected of or known to be compromised. Customized Approach Objective Knowledge of wireless encryption keys cannot allow unauthorized access to wireless networks.",
      "definedApproach": {
        "requirement": "For wireless environments connected to the CDE or transmitting account data, wireless encryption keys are changed as follows: • Whenever personnel with knowledge of the key leave the company or the role for which the knowledge was necessary. • Whenever a key is suspected of or known to be compromised. Customized Approach Objective Knowledge of wireless encryption keys cannot allow unauthorized access to wireless networks.",
        "testingProcedures": []
      },
      "customizedApproach": {
        "objective": "Knowledge of wireless encryption keys cannot allow unauthorized access to wireless networks.",
        "exampleImplementations": []
      }
    },
    {
