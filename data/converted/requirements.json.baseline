    {
      "id": "1.2.2",
      "number": "1.2.2",
      "level": 3,
      "parentId": "1.2",
      "title": "All changes to network connections and to configurations of NSCs are approved and managed in accorda...",
      "statement": "All changes to network connections and to configurations of NSCs are approved and managed in accordance with the change control process defined at Requirement 6.5.1.",
