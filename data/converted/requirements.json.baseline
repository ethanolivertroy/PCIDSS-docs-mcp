    {
      "id": "10.1.1",
      "number": "10.1.1",
      "level": 3,
      "parentId": "10.1",
      "title": "All security policies and operational procedures that are identified in Requirement 10 are: • Docume...",
      "statement": "All security policies and operational procedures that are identified in Requirement 10 are: • Documented. • Kept up to date. • In use. • Known to all affected parties. Customized Approach Objective Expectations, controls, and oversight for meeting activities within Requirement 10 are defined and adhered to by affected personnel. All supporting activities are repeatable, consistently applied, and conform to management's intent.",
      "definedApproach": {
