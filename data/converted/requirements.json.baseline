      },
      "customizedApproach": {
        "objective": "",
        "exampleImplementations": []
      }
    },
    {
      "id": "12.1",
      "number": "12.1",
      "level": 2,
      "parentId": "12",
      "title": "- 12.1 A comprehensive information security policy that governs and provides direction for protection of the entity's information assets is known and current.",
      "statement": "- 12.1 A comprehensive information security policy that governs and provides direction for protection of the entity's information assets is known and current.",
